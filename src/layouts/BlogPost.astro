---
import Comments from '../components/Comments.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
type Props = CollectionEntry<'posts'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 8px;
			}
			.post-header {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 0.5px solid #eee;
			}
			.post-header h1 {
				font-size: 1.6rem;
				font-weight: 500;
				line-height: 1.3;
				margin: 0 0 0.5rem 0;
				color: #111;
			}
			.date {
				font-size: 0.8rem;
				color: #bbb;
			}
			.last-updated-on {
				font-size: 0.8rem;
				color: #bbb;
				font-style: italic;
			}
			.prose {
				font-size: 0.95rem;
				line-height: 1.8;
				color: #333;
			}
			.prose h2 { font-size: 1.2rem; font-weight: 500; margin: 2rem 0 0.75rem; }
			.prose h3 { font-size: 1rem; font-weight: 500; margin: 1.5rem 0 0.5rem; }
			.prose p { margin: 0 0 1.25rem; }
			.prose a { color: #555; }
			.prose img { max-width: 100%; border-radius: 8px; margin: 1.5rem 0; }
			.back {
				display: inline-block;
				font-size: 0.8rem;
				color: #888;
				text-decoration: none;
				margin-bottom: 2rem;
			}
			.back:hover { color: #111; }
			.comments {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 0.5px solid #eee;
				width: 100%;
				max-width: 100%;
				overflow: hidden;
			}
			.post-desc {
				font-size: 0.9rem;
				color: #888;
				margin: 0.25rem 0 0.5rem 0;
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back" href="/">← All posts</a>
			{heroImage && (
				<div class="hero-image">
					<Image width={1020} height={510} src={heroImage} alt="" />
				</div>
			)}
			<div class="post-header">
				<h1>{title}</h1>
				{description && <p class="post-desc">{description}</p>}
				<div class="date">
					<FormattedDate date={pubDate} />
					{updatedDate && (
						<span class="last-updated-on"> · Last updated on <FormattedDate date={updatedDate} /></span>
					)}
				</div>
			</div>
			<div class="prose">
				<slot />
			</div>
			<Comments pageId={Astro.url.pathname} />
		</main>
		<Footer />
	</body>
</html>