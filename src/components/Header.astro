---
import { SITE_TITLE } from '../consts';
---
<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
			<span class="tagline">Life in the UK — golf, food, travel & more</span>
		</div>
		<div class="nav-links">
			<a href="/posts/">Posts</a>
			<a href="/about">About</a>
		</div>
	</nav>
</header>
<style>
	header {
		border-bottom: 0.5px solid #e5e5e5;
		padding: 1.25rem 1.5rem;
		margin-bottom: 2rem;
	}
	nav {
		max-width: 680px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}
	.brand a {
		font-size: 1rem;
		font-weight: 500;
		text-decoration: none;
		color: #111;
	}
	.tagline {
		display: block;
		font-size: 0.75rem;
		color: #888;
		margin-top: 3px;
	}
	.nav-links {
		display: flex;
		gap: 1.5rem;
	}
	.nav-links a {
		font-size: 0.8rem;
		color: #888;
		text-decoration: none;
	}
	.nav-links a:hover {
		color: #111;
	}
</style>